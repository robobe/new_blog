<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <contributor>
      <authoring_tool>gz_demo</authoring_tool>
    </contributor>
    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_effects>
    <effect id="terrain_effect">
      <profile_COMMON>
        <technique sid="common">
          <lambert>
            <diffuse>
              <color>0.42 0.48 0.36 1</color>
            </diffuse>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="terrain_material" name="terrain_material">
      <instance_effect url="#terrain_effect"/>
    </material>
  </library_materials>
  <library_geometries>
    <geometry id="ground_terrain_geometry" name="ground_terrain_geometry">
      <mesh>
        <source id="ground_terrain_positions">
          <float_array id="ground_terrain_positions_array" count="12">-5 -5 0 5 -5 0 5 5 0 -5 5 0</float_array>
          <technique_common>
            <accessor source="#ground_terrain_positions_array" count="4" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <source id="ground_terrain_normals">
          <float_array id="ground_terrain_normals_array" count="3">0 0 1</float_array>
          <technique_common>
            <accessor source="#ground_terrain_normals_array" count="1" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="ground_terrain_vertices">
          <input semantic="POSITION" source="#ground_terrain_positions"/>
        </vertices>
        <triangles count="2" material="terrain_material">
          <input semantic="VERTEX" source="#ground_terrain_vertices" offset="0"/>
          <input semantic="NORMAL" source="#ground_terrain_normals" offset="1"/>
          <p>0 0 1 0 2 0 0 0 2 0 3 0</p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>
  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="ground_terrain" name="ground_terrain">
        <instance_geometry url="#ground_terrain_geometry">
          <bind_material>
            <technique_common>
              <instance_material symbol="terrain_material" target="#terrain_material"/>
            </technique_common>
          </bind_material>
        </instance_geometry>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>
