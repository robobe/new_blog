    <!-- Betaflight SITL plugin
         Motor mapping: BF QUADX motor_speed[id] → physical rotor joint
         BF[0]=REAR_R(CW)   → rotor_3_joint (model rear-right,  pose -0.13,-0.20)
         BF[1]=FRONT_R(CCW) → rotor_0_joint (model front-right, pose +0.13,-0.22)
         BF[2]=REAR_L(CCW)  → rotor_1_joint (model rear-left,   pose -0.13,+0.20)
         BF[3]=FRONT_L(CW)  → rotor_2_joint (model front-left,  pose +0.13,+0.22) -->
    <plugin name="gz::sim::systems::BetaflightPlugin" filename="BetaflightPlugin">
      <imuName>iris/imu_link::imu_sensor</imuName>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
      <rotor id="0">
        <vel_p_gain>0.01</vel_p_gain>
