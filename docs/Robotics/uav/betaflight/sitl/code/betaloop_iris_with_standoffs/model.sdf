    <!-- Lift/Drag plugins for rotor aerodynamics
         forward vectors must match rotation direction for upward lift:
         - CCW rotors (rotor_0, rotor_1): blade at +cp uses forward +Y, blade at -cp uses forward -Y
         - CW rotors (rotor_2, rotor_3): blade at +cp uses forward -Y, blade at -cp uses forward +Y
         a0=0.025 tuned for ~42% hover throttle with 0.53kg model mass -->

    <!-- rotor_0 (front-right, CCW via BetaflightPlugin) -->
    <plugin name="gz::sim::systems::LiftDrag" filename="gz-sim-lift-drag-system">
      <a0>0.025</a0>
      <alpha_stall>1.4</alpha_stall>
      <cla>0.2500</cla>
      <cda>0.004</cda>
      <cma>0.00</cma>
      <cla_stall>-0.025</cla_stall>
      <cda_stall>0.0</cda_stall>
      <cma_stall>0.0</cma_stall>
      <area>0.2</area>
      <air_density>1.2041</air_density>
      <cp>0.084 0 0</cp>
      <forward>0 1 0</forward>
      <upward>0 0 1</upward>
      <link_name>rotor_0</link_name>
    </plugin>
    <plugin name="gz::sim::systems::LiftDrag" filename="gz-sim-lift-drag-system">
      <a0>0.025</a0>
      <alpha_stall>1.4</alpha_stall>
      <cla>0.2500</cla>
      <cda>0.004</cda>
      <cma>0.00</cma>
      <cla_stall>-0.025</cla_stall>
      <cda_stall>0.0</cda_stall>
      <cma_stall>0.0</cma_stall>
      <area>0.2</area>
      <air_density>1.2041</air_density>
      <cp>-0.084 0 0</cp>
      <forward>0 -1 0</forward>
      <upward>0 0 1</upward>
      <link_name>rotor_0</link_name>
    </plugin>

