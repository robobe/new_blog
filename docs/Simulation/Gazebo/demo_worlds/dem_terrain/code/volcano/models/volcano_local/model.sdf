<?xml version="1.0" ?>
<sdf version="1.9">
    <model name="volcano">
        <static>true</static>
        <link name="link">
            <collision name="collision">
                <geometry>
                    <heightmap>
                        <uri>dem/volcano.tif</uri>
                        <size>128 128 80</size>
