                            <normal>materials/textures/flat_normal.png</normal>
                            <size>1</size>
                        </texture>
                        <texture>
                            <diffuse>materials/textures/grass_diffusespecular.png</diffuse>
                            <normal>materials/textures/flat_normal.png</normal>
                            <size>1</size>
                        </texture>
                        <texture>
                            <diffuse>materials/textures/fungus_diffusespecular.png</diffuse>
                            <normal>materials/textures/flat_normal.png</normal>
                            <size>1</size>
                        </texture>
                        <blend>
                            <min_height>2</min_height>
                            <fade_dist>50</fade_dist>
                        </blend>
                        <blend>
                            <min_height>40</min_height>
                            <fade_dist>50</fade_dist>
                        </blend>
                        <uri>dem/volcano.tif</uri>
                        <size>128 128 80</size>
